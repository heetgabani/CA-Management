# ============================================================
# CA-MANAGE ENVIRONMENT CONFIGURATION
# ============================================================

# App
NODE_ENV=development
APP_PORT=4000
APP_URL=http://localhost:4000
FRONTEND_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://camanage:camanage_secret@localhost:5432/camanage_db
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=20

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-long
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# OTP
OTP_EXPIRES_MINUTES=10

# AWS S3 / Storage
STORAGE_PROVIDER=local
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_S3_BUCKET=ca-manage-docs
AWS_S3_ENDPOINT=

# Local Storage (Dev)
LOCAL_STORAGE_PATH=./uploads

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="CA Manage <noreply@camanage.in>"

# Rate Limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# Encryption
ENCRYPTION_KEY=your-32-char-encryption-key-here!

# Super Admin
SUPER_ADMIN_EMAIL=admin@camanage.in
SUPER_ADMIN_PASSWORD=SuperAdmin@123
